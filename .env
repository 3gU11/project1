# Uvicorn runtime
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_RELOAD=false
UVICORN_LOG_LEVEL=info
UVICORN_WORKERS=2

# App auth / bootstrap
ADMIN_PASSWORD=888

# MySQL (optional, keep defaults if not used)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace_me
MYSQL_DB=rjfinshed

# Optional startup behavior
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True

# Performance Optimization - TTL Cache
# 设置为 true 启用 TTL 缓存替代 lru_cache(maxsize=1)
USE_TTL_CACHE=false
TTL_CACHE_SECONDS=30

# Performance Optimization - Inbound SQL
# 设置为 true 启用 SQL COUNT 替代全表扫描（inbound_to_slot 优化）
USE_INBOUND_SQL_OPTIMIZED=false

# Performance Optimization - Thumbnail Cache
# 缩略图磁盘缓存（默认开启）
THUMBNAIL_CACHE_ENABLED=true
THUMBNAIL_CACHE_MAX_AGE_DAYS=7

# Performance Optimization - Schema Versioning
# Schema 版本控制（启动优化，默认关闭）
USE_SCHEMA_VERSIONING=false

# Performance Optimization - UPSERT
# UPSERT 优化（save_data，默认关闭）
USE_UPSERT_OPTIMIZED=false
